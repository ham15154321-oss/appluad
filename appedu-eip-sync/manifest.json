{
  "manifest_version": 3,
  "name": "Appedu EIP 激勵同步",
  "version": "4.9",
  "description": "從赫綵 EIP 系統同步業績數據到激勵排行榜 — 新增報到統計（已報到/網路/到月底）與七學院個人績效同步",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "*://eip.appedu.com.tw/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "EIP 激勵同步"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
