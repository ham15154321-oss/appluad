{
  "manifest_version": 3,
  "name": "Appedu EIP 激勵同步",
  "version": "1.0",
  "description": "從赫綵 EIP 系統同步業績數據到激勵排行榜",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "*://eip.appedu.com.tw/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "EIP 激勵同步"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
